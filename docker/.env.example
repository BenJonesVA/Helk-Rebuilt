STACK_VERSION=9.4.3
CLUSTER_NAME=helk-cluster
LICENSE=basic

# elastic superuser password (used only by the setup container to bootstrap
# the kibana_system password — Kibana itself authenticates as kibana_system)
ELASTIC_PASSWORD=changeme_elastic
# kibana_system service account password
KIBANA_PASSWORD=changeme_kibana
# logstash_system service account password (monitoring API access only)
LOGSTASH_SYSTEM_PASSWORD=changeme_logstash

# Kibana encryption keys (saved objects / reporting / session security).
# Generate real ones with: docker run --rm docker.elastic.co/kibana/kibana:${STACK_VERSION} bin/kibana-encryption-keys generate
KIBANA_ENCRYPTEDSAVEDOBJECTS_KEY=changeme_generate_a_real_key
KIBANA_REPORTING_KEY=changeme_generate_a_real_key
KIBANA_SECURITY_KEY=changeme_generate_a_real_key

ES_PORT=9200
KIBANA_PORT=5601
# ES container memory: HELK_ES_MEMORY sets the JVM heap explicitly; MEM_LIMIT caps the
# container's total memory (rule of thumb: heap ~= half of MEM_LIMIT).
HELK_ES_MEMORY=1g
MEM_LIMIT=2147483648

# Kafka: fixed cluster ID for the single-node KRaft broker. Generate your own with:
# docker run --rm apache/kafka:4.3.1 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=changeme_generate_a_cluster_id
# Host/IP remote Winlogbeat/Kafka clients outside the Docker network should use to reach
# the broker's EXTERNAL listener (port 9093). "localhost" only works for same-host testing.
ADVERTISED_LISTENER=localhost
