{
  "template": {
    "mappings": {
      "dynamic_templates": [
        {
          "param_fields": {
            "match_pattern": "regex",
            "match": "^param\\d+$",
            "mapping": {
              "type": "text",
              "fields": {
                "keyword": {
                  "ignore_above": 32000,
                  "type": "keyword"
                }
              }
            }
          }
        }
      ]
    }
  },
  "version": 2019090101
}